# ===============================================================
# TEAS — Local Development Environment Variables
# Copy to .env (gitignored) and adjust as needed.
# ===============================================================

# --- PostgreSQL ---
POSTGRES_USER=accounting
POSTGRES_PASSWORD=accounting_dev_password
POSTGRES_DB=accounting_dev

# --- pgAdmin (optional, profile: tools) ---
PGADMIN_EMAIL=admin@local
PGADMIN_PASSWORD=admin

# ===============================================================
# Backend (Accounting.Api) — Tax Configuration
# Mirror in backend/src/Accounting.Api/appsettings.json
# DO NOT expose these via UI. .env is the source of truth.
# ===============================================================

# Company identity
COMPANY_TAX_ID=0000000000000
COMPANY_BRANCH_CODE=00000
COMPANY_NAME_TH=บริษัท เอบีซี จำกัด
COMPANY_NAME_EN=ABC Company Limited

# VAT mode — ALL-or-NOTHING toggle
# true  => issue tax invoices, submit e-Tax, file ภ.พ.30
# false => issue receipts only, no e-Tax, no ภ.พ.30
VAT_MODE=true
VAT_RATE=0.07
VAT_EFFECTIVE_FROM=2024-10-01
VAT_ROUNDING=HALF_UP
VAT_DECIMAL_PLACES=2

# e-Tax (only when VAT_MODE=true)
ETAX_ENABLED=true
ETAX_DELIVERY_EMAIL_CC=csemail@rd.go.th
ETAX_SMTP_HOST=localhost
ETAX_SMTP_PORT=1025
ETAX_SMTP_USERNAME=
ETAX_SMTP_PASSWORD=
ETAX_FROM_EMAIL=accounting@example.com

# CA certificate (PFX file) for XAdES signing
CA_CERT_PFX_PATH=/secrets/company_cert.pfx
CA_CERT_PASSWORD=
CA_PROVIDER=TDID

# ภ.พ.30 submission mode: auto | manual
# auto:   uses RD Open API + auto-submit at 23:00 of day 15
# manual: generates file for accountant to upload via portal
PND30_SUBMISSION_MODE=manual

# Required only if PND30_SUBMISSION_MODE=auto
RD_API_BASE_URL=https://openapi.rd.go.th
RD_API_CLIENT_ID=
RD_API_CLIENT_SECRET=
RD_API_SERVICE_PROVIDER_ID=

# Auto-submit safety net schedule (auto mode only)
AUTO_SUBMIT_PND30_DEADLINE_TIME=23:00
AUTO_SUBMIT_PND3_53_DEADLINE_TIME=23:00
DEADLINE_ALERT_DAYS=3,2,1

# PII encryption key (app-level — base64 of 32 bytes / 256-bit AES)
PII_ENCRYPTION_KEY=

# --- JWT ---
JWT_ISSUER=teas.local
JWT_AUDIENCE=teas.api
JWT_SIGNING_KEY=replace-with-strong-secret-min-256-bits
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# --- Frontend ---
FRONTEND_ORIGIN=http://localhost:3000
