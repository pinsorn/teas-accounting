# Client-side (exposed to browser bundle):
NEXT_PUBLIC_API_URL=http://localhost:5080
NEXT_PUBLIC_APP_NAME=TEAS
NEXT_PUBLIC_DEFAULT_LOCALE=th

# Server-side (Next.js BFF API routes only — never exposed to browser):
# Backend dev server runs on :5080 via ASPNETCORE_URLS override
# (default Kestrel :5000 fallback in BFF routes will break login if this is missing).
BACKEND_API_URL=http://localhost:5080
